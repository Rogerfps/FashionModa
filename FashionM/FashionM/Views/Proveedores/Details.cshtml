@model Proveedor

<h2 class="mb-4">Detalle del Proveedor</h2>

<!-- =========================
     DATOS DEL PROVEEDOR
========================== -->
<div class="card mb-4">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Cédula</dt>
            <dd class="col-sm-9">@Model.Cedula</dd>

            <dt class="col-sm-3">Nombre</dt>
            <dd class="col-sm-9">@Model.Nombre @Model.Apellidos</dd>

            <dt class="col-sm-3">Tipo Identificación</dt>
            <dd class="col-sm-9">@Model.IDTipo</dd>

            <dt class="col-sm-3">Correo</dt>
            <dd class="col-sm-9">@Model.Correo</dd>

            <dt class="col-sm-3">Teléfono</dt>
            <dd class="col-sm-9">@Model.Telefono</dd>

            <dt class="col-sm-3">Comercio</dt>
            <dd class="col-sm-9">@Model.Comercio</dd>

            <dt class="col-sm-3">Dirección</dt>
            <dd class="col-sm-9">@Model.Direccion</dd>

            <dt class="col-sm-3">Actividad Económica</dt>
            <dd class="col-sm-9">@Model.Actividad</dd>

            <dt class="col-sm-3">Estado</dt>
            <dd class="col-sm-9">
                <span class="badge @(Model.Estado ? "bg-success" : "bg-secondary")">
                    @(Model.Estado ? "Activo" : "Inactivo")
                </span>
            </dd>
        </dl>

        <a asp-action="Edit" asp-route-id="@Model.Cedula" class="btn btn-warning">
            Editar
        </a>
        <a asp-action="Index" class="btn btn-secondary ms-2">
            Volver
        </a>
    </div>
</div>

<!-- =========================
     CÓDIGOS / COLORES / SUELAS
========================== -->
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <strong>Zapatos del Proveedor</strong>

            <a asp-controller="Zapatos"
               asp-action="Create"
               asp-route-proveedorCedula="@Model.Cedula"
               class="btn btn-sm btn-primary">
                + Nuevo Zapato
            </a>
        </div>

        <div class="card-body">

            @if (Model.Zapatos != null && Model.Zapatos.Any())
            {
                <table class="table table-bordered table-striped">
                    <thead>
                        <tr>
                            <th>Código</th>
                            <th>Color</th>
                            <th>Suela</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var zapato in Model.Zapatos)
                        {
                            <tr>
                                <td>@zapato.Codigo</td>
                                <td>@zapato.Color</td>
                                <td>@zapato.Suela</td>
                                <td>
                                    <a asp-controller="Zapatos"
                                       asp-action="Edit"
                                       asp-route-id="@zapato.Id"
                                       class="btn btn-sm btn-warning">
                                        Editar
                                    </a>
                                    <a asp-controller="Zapatos"
                                       asp-action="Delete"
                                       asp-route-id="@zapato.Id"
                                       class="btn btn-sm btn-danger ms-1">
                                        Eliminar
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted">
                    Este proveedor no tiene zapatos registrados.
                </p>
            }
        </div>
    </div>
