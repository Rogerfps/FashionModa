@model Proveedor

<h2 class="mb-4">Detalle del Proveedor</h2>

<!-- =========================
     DATOS DEL PROVEEDOR
========================== -->
<div class="card mb-4">
    <div class="card-body">

        <dl class="row">
            <dt class="col-sm-3">Cédula</dt>
            <dd class="col-sm-9">@Model.Cedula</dd>

            <dt class="col-sm-3">Nombre</dt>
            <dd class="col-sm-9">@Model.Nombre @Model.Apellidos</dd>

            <dt class="col-sm-3">Tipo Identificación</dt>
            <dd class="col-sm-9">@Model.IDTipo</dd>

            <dt class="col-sm-3">Correo</dt>
            <dd class="col-sm-9">@Model.Correo</dd>

            <dt class="col-sm-3">Teléfono</dt>
            <dd class="col-sm-9">@Model.Telefono</dd>

            <dt class="col-sm-3">Comercio</dt>
            <dd class="col-sm-9">@Model.Comercio</dd>

            <dt class="col-sm-3">Dirección</dt>
            <dd class="col-sm-9">@Model.Direccion</dd>

            <dt class="col-sm-3">Actividad Económica</dt>
            <dd class="col-sm-9">@Model.Actividad</dd>

            <dt class="col-sm-3">Estado</dt>
            <dd class="col-sm-9">
                <span class="badge @(Model.Estado ? "bg-success" : "bg-secondary")">
                    @(Model.Estado ? "Activo" : "Inactivo")
                </span>
            </dd>
        </dl>

        <a asp-action="Edit"
           asp-route-id="@Model.Cedula"
           class="btn btn-warning">
            Editar
        </a>

        <a asp-action="Index" class="btn btn-secondary ms-2">
            Volver
        </a>
    </div>
</div>

<!-- =========================
     CÓDIGOS / COLORES / SUELAS
========================== -->
<div class="card">
    <div class="card-header">
        <strong>Códigos del Proveedor</strong>
    </div>

    <div class="card-body">

        @if (Model.Codigos != null && Model.Codigos.Any())
        {
            foreach (var codigo in Model.Codigos)
            {
                <div class="border rounded p-3 mb-3">

                    <h5>Código: @codigo.NombreCodigo</h5>

                    @if (codigo.Colores != null && codigo.Colores.Any())
                    {
                        <ul>
                            @foreach (var color in codigo.Colores)
                            {
                                <li>
                                    <strong>Color:</strong> @color.NombreColor

                                    @if (color.Suelas != null && color.Suelas.Any())
                                    {
                                        <ul>
                                            @foreach (var suela in color.Suelas)
                                            {
                                                <li>
                                                    Suela: @suela.TipoSuela
                                                </li>
                                            }
                                        </ul>
                                    }
                                    else
                                    {
                                        <span class="text-muted">
                                            (Sin suelas registradas)
                                        </span>
                                    }
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted">
                            Este código no tiene colores registrados.
                        </p>
                    }

                </div>
            }
        }
        else
        {
            <p class="text-muted">
                Este proveedor no tiene códigos registrados.
            </p>
        }

    </div>
</div>