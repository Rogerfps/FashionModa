@model IEnumerable<MovimientoInventario>

@{
    ViewData["Title"] = "Movimientos de Inventario";
}

<link rel="stylesheet" href="~/css/Inventario/Movimientos.css" />

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>📦 Movimientos de Inventario</h2>
        <a asp-action="Create" class="btn btn-primary">
            + Nuevo Movimiento
        </a>
    </div>

    <table class="table table-bordered table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Fecha</th>
                <th>Marca</th>
                <th>Código</th>
                <th>Color</th>
                <th>Tipo</th>
                <th>Cantidad</th>
                <th>Detalle Numeración</th>
                <th style="width:120px;">Acciones</th>
            </tr>
        </thead>

        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="8" class="text-center text-muted">
                        No hay movimientos registrados
                    </td>
                </tr>
            }
            else
            {
                foreach (var item in Model)
                {
                    var total = item.Detalles.Sum(d => d.Cantidad);

                    <tr>
                        <td>@item.Fecha.ToString("dd/MM/yyyy HH:mm")</td>

                        <td>@item.Inventario?.Marca</td>

                        <td>@item.InventarioCodigo</td>

                        <td>
                            @if (item.Tipo == "Entrada")
                            {
                                <span class="badge bg-success">Entrada</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Salida</span>
                            }
                        </td>

                        <td>
                            @if (item.Tipo == "Entrada")
                            {
                                <span class="text-success fw-bold">+@total</span>
                            }
                            else
                            {
                                <span class="text-danger fw-bold">-@total</span>
                            }
                        </td>

                        <td>
                            @foreach (var d in item.Detalles)
                            {
                                <span class="badge bg-secondary me-1">
                                    @d.Numero (@d.Cantidad)
                                </span>
                            }
                        </td>

                        <td>
                            <a asp-action="Details" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-info">
                                Ver
                            </a>

                            <a asp-action="Delete" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-danger">
                                Borrar
                            </a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>


    <!-- PAGINACION -->
    @if (ViewBag.TotalPages > 1)
    {
        <nav>
            <ul class="pagination justify-content-center">

                @if (ViewBag.CurrentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@(ViewBag.CurrentPage - 1)">
                            ←
                        </a>
                    </li>
                }

                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@i">
                            @i
                        </a>
                    </li>
                }

                @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@(ViewBag.CurrentPage + 1)">
                            →
                        </a>
                    </li>
                }

            </ul>
        </nav>
    }

</div>
