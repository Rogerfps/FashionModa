@using FashionM.Enums

@model IEnumerable<PedidoCliente>

@{
    ViewData["Title"] = "Pedidos de Clientes";
}

<h2>Pedidos de Clientes</h2>

<p>
    <a asp-action="Index" class="btn btn-secondary">Actualizar</a>
    <a asp-action="Create" class="btn btn-primary ms-2">➕ Crear Pedido</a>
</p>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>#</th>
            <th>Fecha</th>
            <th>Cliente</th>
            <th>Transporte</th>
            <th>Total</th>
            <th>Crédito</th>
            <th>Bodega</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.FechaPedido.ToString("dd/MM/yyyy")</td>
                <td>
                    @item.Cliente.Nombre @item.Cliente.Apellidos<br />
                    <small>@item.Cliente.Cedula</small>
                </td>
                <td>@item.Cliente.Transporte</td>
                <td>₡ @item.Total.ToString("N2")</td>

                <!-- ESTADO CRÉDITO -->
                <td>
                    @switch (item.EstadoCredito)
                    {
                        case EstadoCredito.Aprobado:
                            <span class="badge bg-success">Aprobado</span>
                            break;
                        case EstadoCredito.Rechazado:
                            <span class="badge bg-danger">Rechazado</span>
                            break;
                        case EstadoCredito.Retenido:
                            <span class="badge bg-warning text-dark">Retenido</span>
                            break;
                        default:
                            <span class="badge bg-secondary">Pendiente</span>
                            break;
                    }
                </td>

                <!-- ESTADO BODEGA -->
                <td>
                    @if (item.FirmaBodega)
                    {
                        <span class="badge bg-success">Despachado</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Pendiente</span>
                    }
                </td>

                <!-- ACCIONES -->
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Ver</a>

                    @* Acciones de Crédito *@
                    @if (item.EstadoCredito == EstadoCredito.Pendiente || item.EstadoCredito == EstadoCredito.Retenido)
                    {
                        <form asp-action="AprobarCredito" asp-route-id="@item.Id" method="post" style="display:inline">
                            <button type="submit" class="btn btn-sm btn-success">Aprobar</button>
                        </form>

                        <form asp-action="RechazarCredito" asp-route-id="@item.Id" method="post" style="display:inline">
                            <button type="submit" class="btn btn-sm btn-danger">Rechazar</button>
                        </form>

                        <form asp-action="RetenerCredito" asp-route-id="@item.Id" method="post" style="display:inline">
                            <button type="submit" class="btn btn-sm btn-warning">Retener</button>
                        </form>
                    }

                    @* Acción de Bodega *@
                    @if (item.EstadoCredito == EstadoCredito.Aprobado && !item.FirmaBodega)
                    {
                        <form asp-action="FirmarBodega" asp-route-id="@item.Id" method="post" style="display:inline">
                            <button type="submit" class="btn btn-sm btn-primary">Bodega</button>
                        </form>
                    }

                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>