@model Inventario

@{
    ViewData["Title"] = "Editar Inventario";
}

<link rel="stylesheet" href="~/css/Inventario/InventarioEdit.css" />

<div class="neo-header">
    <div class="container d-flex justify-content-between align-items-center px-3">
        <h1 class="title-glow">✏️ Editar Inventario</h1>
        <a asp-action="Index" class="back-link">← Volver</a>
    </div>
</div>

<div class="container px-3" style="max-width: 1000px;">
    <div class="form-card">

        <form asp-action="Edit" method="post" enctype="multipart/form-data">

            @Html.AntiForgeryToken()

            <div asp-validation-summary="All" class="text-danger"></div>

            <input type="hidden" asp-for="Codigo" />

            <label>Marca</label>
            <input asp-for="Marca" class="form-control mb-2" />

            <label>SKU</label>
            <input asp-for="SKU" class="form-control mb-2" />

            <div class="mb-3">
                <label asp-for="CodigoCabys" class="form-label">Código CABYS</label>
                <input asp-for="CodigoCabys" class="form-control" />
                <span asp-validation-for="CodigoCabys" class="text-danger"></span>
            </div>

            <label>Empresa</label>
            <input asp-for="Empresa" class="form-control mb-2" />

            <div class="row mb-3">
                <div class="col">
                    <label>Precio costo</label>
                    <input asp-for="PrecioCosto" class="form-control" />
                </div>
                <div class="col">
                    <label>Precio venta</label>
                    <input asp-for="PrecioVenta" class="form-control" />
                </div>
            </div>

            <hr />

            <h4>Variantes</h4>

            <table class="table table-bordered" id="tablaTallas">

                <thead>
                    <tr>
                        <th>Color</th>
                        <th>Detalle</th>
                        <th>Talla</th>
                        <th>Cantidad</th>
                        <th></th>
                    </tr>
                </thead>

                <tbody>

                    @for (int i = 0; i < Model.Tallas.Count; i++)
                    {
                        <tr>

                            <td>
                                <input type="hidden" name="Tallas[@i].Id" value="@Model.Tallas[i].Id" />

                                <input name="Tallas[@i].Color"
                                       value="@Model.Tallas[i].Color"
                                       class="form-control" />
                            </td>

                            <td>
                                <input name="Tallas[@i].Detalle"
                                       value="@Model.Tallas[i].Detalle"
                                       class="form-control" />
                            </td>

                            <td>
                                <input name="Tallas[@i].Numero"
                                       value="@Model.Tallas[i].Numero"
                                       class="form-control" />
                            </td>

                            <td>
                                <input name="Tallas[@i].Cantidad"
                                       value="@Model.Tallas[i].Cantidad"
                                       type="number"
                                       class="form-control" />
                            </td>

                            <td>
                                <button type="button"
                                        class="btn btn-danger"
                                        onclick="removeRow(this)">
                                    X
                                </button>
                            </td>

                        </tr>
                    }

                </tbody>

            </table>

            <button type="button"
                    class="btn btn-secondary mb-3"
                    onclick="addRow()">
                ➕ Nueva Variante
            </button>

            <hr />

            <label>Agregar fotos</label>
            <input type="file"
                   name="nuevasFotos"
                   multiple
                   class="form-control mb-3" />

            <button class="btn btn-success">Guardar</button>
            <a asp-action="Index" class="btn btn-secondary">Volver</a>

        </form>

    </div>
</div>

@section Scripts {

    <script>

        function addRow(){

        let table = document.querySelector("#tablaTallas tbody");
        let i = table.rows.length;

        table.insertAdjacentHTML("beforeend",

        `<tr>

        <td>
        <input name="Tallas[${i}].Color"
        class="form-control"/>
        </td>

        <td>
        <input name="Tallas[${i}].Detalle"
        class="form-control"/>
        </td>

        <td>
        <input name="Tallas[${i}].Numero"
        class="form-control"/>
        </td>

        <td>
        <input name="Tallas[${i}].Cantidad"
        type="number"
        value="0"
        class="form-control"/>
        </td>

        <td>
        <button type="button"
        class="btn btn-danger"
        onclick="removeRow(this)">
        X
        </button>
        </td>

        </tr>`

        );

        }

        function removeRow(btn){

        btn.closest("tr").remove();

        }

    </script>

}