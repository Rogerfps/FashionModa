@model Inventario

@{
var tallas = Model.Tallas
.Select(t => t.Numero)
.Distinct()
.OrderBy(t => t)
.ToList();

var grupos = Model.Tallas
.GroupBy(t => new { t.Color, t.Detalle })
.ToList();
}

<h2 class="mb-4">Detalle del Producto</h2>

<!-- =========================
     DATOS DEL PRODUCTO
========================== -->
<div class="card mb-4">
    <div class="card-body">

        <dl class="row">

            <dt class="col-sm-3">Código</dt>
            <dd class="col-sm-9">@Model.Codigo</dd>

            <dt class="col-sm-3">Marca</dt>
            <dd class="col-sm-9">@Model.Marca</dd>

            <dt class="col-sm-3">SKU</dt>
            <dd class="col-sm-9">@Model.SKU</dd>

            <dt class="col-sm-3">Empresa</dt>
            <dd class="col-sm-9">@Model.Empresa</dd>

            <dt class="col-sm-3">CABYS</dt>
            <dd class="col-sm-9">@Model.CodigoCabys</dd>

            <dt class="col-sm-3">Costo</dt>
            <dd class="col-sm-9">₡@Model.PrecioCosto.ToString("N0")</dd>

            <dt class="col-sm-3">Venta</dt>
            <dd class="col-sm-9">₡@Model.PrecioVenta.ToString("N0")</dd>

            <dt class="col-sm-3">Stock Total</dt>
            <dd class="col-sm-9">@Model.StockTotal</dd>

        </dl>

        <a asp-action="Edit" asp-route-id="@Model.Codigo" class="btn btn-warning">
            Editar
        </a>

        <a asp-action="Index" class="btn btn-secondary ms-2">
            Volver
        </a>

    </div>
</div>


<!-- =========================
     VARIANTES DEL PRODUCTO
========================== -->
<div class="card">

    <div class="card-header d-flex justify-content-between align-items-center">

        <strong>Variantes del Producto</strong>

        <a asp-action="Edit"
               asp-route-id="@Model.Codigo"
               class="btn btn-sm btn-primary">
            + Nueva Variante
        </a>

    </div>

    <div class="card-body">

        @if (Model.Tallas != null && Model.Tallas.Any())
        {

            <table class="table table-bordered align-middle">

                <thead>
                    <tr>
                        <th>Color</th>
                        <th>Detalle</th>

                        @foreach (var talla in tallas)
                        {
                            <th class="text-center">@talla</th>
                        }

                        <th>Total</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var g in grupos)
                    {
                        <tr>

                            <td>@g.Key.Color</td>
                            <td>@g.Key.Detalle</td>

                            @foreach (var talla in tallas)
                            {
                                var item = g.FirstOrDefault(x => x.Numero == talla);

                                <td class="text-center">
                                    @(item?.Cantidad ?? 0)
                                </td>
                            }

                            <td class="fw-bold text-center">
                                @g.Sum(x => x.Cantidad)
                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        }
        else
        {
            <p class="text-muted">
                Este producto no tiene variantes registradas.
            </p>
        }

    </div>
</div>


<!-- =========================
     FOTOS
========================== -->
<div class="card mt-4">

    <div class="card-header">
        <strong>Fotos del Producto</strong>
    </div>

    <div class="card-body">

        @if (Model.Fotos != null && Model.Fotos.Any())
        {

            <div class="d-flex flex-wrap gap-2">

                @foreach (var foto in Model.Fotos)
                {
                    <div>

                        <img src="@foto.Ruta"
                             class="img-thumbnail"
                             style="width:90px;height:90px;object-fit:cover" />

                        <form asp-action="DeleteFoto" method="post" class="mt-1">

                            @Html.AntiForgeryToken()

                            <input type="hidden" name="id" value="@foto.Id" />
                            <input type="hidden" name="inventarioCodigo" value="@Model.Codigo" />

                            <button class="btn btn-sm btn-danger">
                                Eliminar
                            </button>

                        </form>

                    </div>
                }

            </div>

        }
        else
        {
            <span class="text-muted">Sin imágenes</span>
        }

    </div>

</div>