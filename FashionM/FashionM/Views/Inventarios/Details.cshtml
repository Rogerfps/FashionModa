@model Inventario
@{
    ViewData["Title"] = "Detalle de Inventario";
}

<link rel="stylesheet" href="~/css/Inventario/InventarioDetails.css" />

<!-- HEADER -->
<div class="neo-header">
    <div class="container d-flex justify-content-between align-items-center px-3">
        <h1 class="title-glow">📦 Detalle del Producto</h1>
        <a asp-action="Index" class="back-link">← Volver al listado</a>
    </div>
</div>

<div class="container px-3" style="max-width: 1100px;">
    <div class="detail-card">
        <!-- Badges superiores -->
        <div style="display: flex; gap: 0.8rem; flex-wrap: wrap; margin-bottom: 1.5rem;">
            <span class="badge">Código: @Model.Codigo</span>
            <span class="badge">@Model.Marca</span>
            <span class="badge">@Model.Color</span>
        </div>

        <!-- Grid de información principal -->
        <div class="info-grid">
            <div class="info-item">
                <span class="info-label">Código</span>
                <span class="info-value">@Model.Codigo</span>
            </div>
            <div class="info-item">
                <span class="info-label">SKU</span>
                <span class="info-value">@Model.SKU</span>
            </div>
            <div class="info-item">
                <span class="info-label">Marca</span>
                <span class="info-value">@Model.Marca</span>
            </div>
            <div class="info-item">
                <span class="info-label">Color</span>
                <span class="info-value">@Model.Color</span>
            </div>
            <div class="info-item">
                <span class="info-label">Empresa</span>
                <span class="info-value">@Model.Empresa</span>
            </div>
            <div class="info-item">
                <span class="info-label">CABYS</span>
                <span class="info-value">@Model.CodigoCabys</span>
            </div>
            <div class="info-item">
                <span class="info-label">Costo</span>
                <span class="info-value">₡@Model.PrecioCosto.ToString("N0")</span>
            </div>
            <div class="info-item">
                <span class="info-label">Venta</span>
                <span class="info-value" style="color: #10b981; font-weight: 600;">₡@Model.PrecioVenta.ToString("N0")</span>
            </div>
        </div>

        <!-- Detalle del producto -->
        @if (!string.IsNullOrEmpty(Model.Detalle))
        {
            <div class="section-title">📝 Descripción</div>
            <div class="detalle-texto">@Model.Detalle</div>
        }

        <!-- SECCIÓN TALLAS -->
        <div class="section-title">
            <span>👟</span> Tallas y Stock (@(Model.Tallas?.Count() ?? 0))
        </div>

        @if (Model.Tallas != null && Model.Tallas.Any())
        {
            var tallas = Model.Tallas;

            <div class="tabla-tallas-wrapper">
                <table class="tabla-tallas">
                    <thead>
                        <tr>
                            <th>Talla</th>
                            <th>A</th>
                            <th>B</th>

                            @for (int i = 15; i <= 45; i++)
                            {
                                <th>@i</th>
                            }
                        </tr>
                    </thead>

                    <tbody>
                        <tr>
                            <td>Stock</td>

                            <!-- Talla A -->
                            @{
                                var tallaA = tallas.FirstOrDefault(t => t.Numero == "A");
                            }
                            <td>@(tallaA?.Cantidad ?? 0)</td>

                            <!-- Talla B -->
                            @{
                                var tallaB = tallas.FirstOrDefault(t => t.Numero == "B");
                            }
                            <td>@(tallaB?.Cantidad ?? 0)</td>

                            <!-- Tallas 15 a 45 -->
                            @for (int i = 15; i <= 45; i++)
                            {
                                var talla = tallas.FirstOrDefault(t => t.Numero == i.ToString());
                                <td>@(talla?.Cantidad ?? 0)</td>
                            }

                        </tr>
                    </tbody>
                </table>
            </div>
        }

        <!-- SECCIÓN FOTOS -->
        <div class="section-title">
            <span>📷</span> Fotos del Producto (@(Model.Fotos?.Count() ?? 0))
        </div>

        @if (Model.Fotos != null && Model.Fotos.Any())
        {
            <div class="fotos-grid">
                @foreach (var foto in Model.Fotos)
                {
                    <div class="foto-item">
                        <img src="@foto.Ruta" class="foto-img" />
                        <form asp-action="DeleteFoto" method="post" onsubmit="return confirm('¿Eliminar esta imagen?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@foto.Id" />
                            <input type="hidden" name="inventarioCodigo" value="@Model.Codigo" />
                            <button type="submit" class="btn-delete-foto">🗑 Eliminar foto</button>
                        </form>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-message">📸 No hay fotos disponibles para este producto</div>
        }

        <!-- BOTONES DE ACCIÓN -->
        <div class="action-buttons">
            <a asp-action="Index" class="btn-secondary">← Volver</a>
            <a asp-action="Edit" asp-route-id="@Model.Codigo" class="btn-warning">✏️ Editar producto</a>
        </div>
    </div>
</div>