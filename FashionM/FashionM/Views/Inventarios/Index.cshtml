@model IEnumerable<FashionM.Models.Inventario>
@{
    ViewData["Title"] = "Inventario";
}

<link rel="stylesheet" href="~/css/Inventario/InventarioIndex.css" />

<!-- HEADER COMPACTO -->
<div class="neo-header">
    <div class="container d-flex justify-content-between align-items-center px-4">
        <h1 class="title-glow">📦 Inventario</h1>
        <a asp-action="Create" class="btn-neo">➕ Nuevo</a>
    </div>
</div>

<div class="container-fluid px-4" style="max-width: 1400px;">

    <!-- FILTRO COMPACTO -->
    <form asp-action="Index" method="get" class="filter-container d-flex gap-2">

        <!-- BUSCAR -->
        <input type="text"
               name="search"
               value="@ViewBag.Search"
               class="filter-input flex-grow-1"
               placeholder="Buscar...">

        <!-- EMPRESA -->
        <select name="empresa" class="filter-input">
            <option value="">Todas las empresas</option>

            @foreach (var e in ViewBag.Empresas)
            {
                <option value="@e" selected="@(ViewBag.Empresa == e)">
                    @e
                </option>
            }
        </select>

        <!-- BOTON BUSCAR -->
        <button type="submit" class="btn-filter">🔍</button>

        <!-- LIMPIAR -->
        @if (!string.IsNullOrEmpty(ViewBag.Search) || !string.IsNullOrEmpty(ViewBag.Empresa))
        {
            <a asp-action="Index" class="btn-filter" style="background:#ef4444;">✖</a>
        }

    </form>

    <!-- TABLA COMPACTA -->
    <div class="table-wrap">
        <div class="table-responsive">
            <table class="modern-table">
                <thead>
                    <tr>
                        <th style="width:120px"></th>
                        <th>Código</th>
                        <th>Producto</th>
                        <th>SKU</th>
                        <th>Precios</th>
                        <th>Tallas</th>
                        <th>Stock</th>
                        <th></th>
                    </tr>
                </thead>

                <tbody>

                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5">📭 Sin productos</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>

                                <!-- FOTO -->
                                <td>
                                    @if (item.Fotos?.Any() == true)
                                    {
                                        <img src="@item.Fotos.First().Ruta" class="product-img">
                                    }
                                    else
                                    {
                                        <div class="no-img">📷</div>
                                    }
                                </td>

                                <!-- CODIGO -->
                                <td class="fw-semibold">@item.Codigo</td>

                                <!-- PRODUCTO -->
                                <td>
                                    <div class="product-line">@item.Marca</div>
                                    
                                </td>

                                <!-- SKU -->
                                <td>
                                    <span style="font-family:monospace">@item.SKU</span>
                                </td>

                                <!-- PRECIOS -->
                                <td>
                                    <div class="precio-venta">
                                        ₡@item.PrecioVenta.ToString("N0")
                                    </div>
                                    <div class="precio-costo">
                                        ₡@item.PrecioCosto.ToString("N0")
                                    </div>
                                </td>

                                <!-- TALLAS -->
                                <td>
                                    @if (item.Tallas?.Any() == true)
                                    {
                                        @foreach (var t in item.Tallas.OrderBy(t => t.Numero).Take(3))
                                        {
                                            <span class="talla-badge">
                                                @t.Numero:@t.Cantidad
                                            </span>
                                        }

                                        @(item.Tallas.Count() > 3 ? "..." : "")
                                    }
                                </td>

                                <!-- STOCK -->
                                <td>
                                    <span class="stock-badge">
                                        @item.StockTotal
                                    </span>
                                </td>

                                <!-- ACCIONES -->
                                <td>
                                    <div class="action-group">

                                        <a asp-action="Details"
                                           asp-route-id="@item.Codigo"
                                           class="btn-action btn-view"
                                           title="Ver">
                                            👁
                                        </a>

                                        <a asp-action="Edit"
                                           asp-route-id="@item.Codigo"
                                           class="btn-action btn-edit"
                                           title="Editar">
                                            ✏️
                                        </a>

                                        <form asp-action="Delete"
                                              method="post"
                                              style="display:inline;"
                                              onsubmit="return confirm('¿Eliminar?')">

                                            @Html.AntiForgeryToken()

                                            <input type="hidden"
                                                   name="codigo"
                                                   value="@item.Codigo">

                                            <button type="submit"
                                                    class="btn-action btn-delete"
                                                    title="Eliminar">
                                                🗑
                                            </button>

                                        </form>

                                    </div>
                                </td>

                            </tr>
                        }
                    }

                </tbody>
            </table>
        </div>
    </div>

    <!-- PAGINACIÓN -->
    @if (ViewBag.TotalPages > 1)
    {
        <div class="pagination-compact">

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <a asp-action="Index"
                   asp-route-page="@i"
                   asp-route-search="@ViewBag.Search"
                   asp-route-empresa="@ViewBag.Empresa"
                   class="page-compact @(i == ViewBag.CurrentPage ? "active" : "")">

                    @i

                </a>
            }

        </div>
    }

</div>