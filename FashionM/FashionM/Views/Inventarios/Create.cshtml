@model FashionM.Models.Inventario
@{
    ViewData["Title"] = "Nuevo Inventario";
}

<link rel="stylesheet" href="~/css/Inventario/InventarioCreate.css" />

<!-- HEADER MINI -->
<div class="neo-header">
    <div class="container d-flex justify-content-between align-items-center px-3">
        <h1 class="title-glow">✨ Nuevo</h1>
        <a asp-action="Index" class="back-link">←</a>
    </div>
</div>

<div class="container px-3" style="max-width: 900px;">
    <div class="form-card">

        <div asp-validation-summary="All" class="validation-summary"></div>

        <form asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <!-- GRID -->
            <div class="form-grid">

                <div class="form-group">
                    <label asp-for="Codigo"></label>
                    <input asp-for="Codigo" class="form-control" />
                    <span asp-validation-for="Codigo" class="validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="SKU"></label>
                    <input asp-for="SKU" class="form-control" />
                </div>

                <div class="form-group">
                    <label asp-for="Marca"></label>
                    <input asp-for="Marca" class="form-control" />
                </div>

                <div class="form-group">
                    <label asp-for="PrecioCosto"></label>
                    <input asp-for="PrecioCosto" type="number" step="0.01" class="form-control" />
                </div>

                <div class="form-group">
                    <label asp-for="PrecioVenta"></label>
                    <input asp-for="PrecioVenta" type="number" step="0.01" class="form-control" />
                </div>

                <div class="form-group">
                    <label asp-for="CodigoCabys"></label>
                    <input asp-for="CodigoCabys" class="form-control" />
                </div>

                <div class="form-group">
                    <label asp-for="Empresa"></label>
                    <input asp-for="Empresa" class="form-control" />
                </div>

            </div>

            <!-- TALLAS -->
            <div class="section-title">📏 Variantes</div>

            <table class="tallas-table" id="tablaTallas">

                <thead>
                    <tr>
                        <th>Color</th>
                        <th>Detalle</th>
                        <th>Talla</th>
                        <th>Cantidad</th>
                        <th></th>
                    </tr>
                </thead>

                <tbody>

                    <tr>
                        <td>
                            <input type="text" name="Tallas[0].Color" placeholder="Negro" required />
                        </td>

                        <td>
                            <input type="text" name="Tallas[0].Detalle" placeholder="Cuero" />
                        </td>

                        <td>
                            <input type="text" name="Tallas[0].Numero" placeholder="38" required />
                        </td>

                        <td>
                            <input type="number" name="Tallas[0].Cantidad" value="0" required />
                        </td>

                        <td></td>
                    </tr>

                </tbody>

            </table>

            <button type="button" class="btn-add" onclick="agregarTalla()">➕ Agregar</button>


            <!-- FOTOS -->
            <div class="section-title">📸 Fotos</div>

            <input type="file" name="imagenes" multiple class="file-input" />


            <!-- BOTONES -->
            <div class="action-buttons">
                <a asp-action="Index" class="btn-secondary">Cancelar</a>
                <button type="submit" class="btn-primary">💾 Guardar</button>
            </div>

        </form>

    </div>
</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

    <script>

        let idx = 1;

        function agregarTalla() {

            const tabla = document.querySelector("#tablaTallas tbody");

            tabla.insertAdjacentHTML("beforeend", `
                <tr>

                    <td>
                        <input type="text" name="Tallas[${idx}].Color" placeholder="Negro" required />
                    </td>

                    <td>
                        <input type="text" name="Tallas[${idx}].Detalle" placeholder="Cuero" />
                    </td>

                    <td>
                        <input type="text" name="Tallas[${idx}].Numero" placeholder="38" required />
                    </td>

                    <td>
                        <input type="number" name="Tallas[${idx}].Cantidad" value="0" required />
                    </td>

                    <td>
                        <button type="button" class="btn-remove" onclick="eliminarFila(this)">✕</button>
                    </td>

                </tr>
            `);

            idx++;
        }

        function eliminarFila(btn) {

            btn.closest("tr").remove();

            reindexar();
        }

        function reindexar() {

            const filas = document.querySelectorAll("#tablaTallas tbody tr");

            filas.forEach((fila, i) => {

                fila.querySelectorAll("input")[0].setAttribute("name", `Tallas[${i}].Color`);
                fila.querySelectorAll("input")[1].setAttribute("name", `Tallas[${i}].Detalle`);
                fila.querySelectorAll("input")[2].setAttribute("name", `Tallas[${i}].Numero`);
                fila.querySelectorAll("input")[3].setAttribute("name", `Tallas[${i}].Cantidad`);

            });

            idx = filas.length;
        }

    </script>

}