@model FashionM.Models.Inventario
@{
    ViewData["Title"] = "Nuevo Inventario";
}

<link rel="stylesheet" href="~/css/Inventario/InventarioCreate.css" />

<!-- HEADER MINI -->
<div class="neo-header">
    <div class="container d-flex justify-content-between align-items-center px-3">
        <h1 class="title-glow">✨ Nuevo</h1>
        <a asp-action="Index" class="back-link">←</a>
    </div>
</div>

<div class="container px-3" style="max-width: 900px;">
    <div class="form-card">
        <div asp-validation-summary="All" class="validation-summary"></div>

        <form asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <!-- Grid 2 columnas -->
            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="Codigo">Código</label>
                    <input asp-for="Codigo" class="form-control" placeholder="PROD001" />
                    <span asp-validation-for="Codigo" class="validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="SKU">SKU</label>
                    <input asp-for="SKU" class="form-control" placeholder="SKU123" />
                    <span asp-validation-for="SKU" class="validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Marca">Marca</label>
                    <input asp-for="Marca" class="form-control" placeholder="Nike" />
                    <span asp-validation-for="Marca" class="validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Color">Color</label>
                    <input asp-for="Color" class="form-control" placeholder="Rojo" />
                    <span asp-validation-for="Color" class="validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="PrecioCosto">Costo (₡)</label>
                    <input asp-for="PrecioCosto" type="number" step="0.01" class="form-control" placeholder="0.00" />
                    <span asp-validation-for="PrecioCosto" class="validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="PrecioVenta">Venta (₡)</label>
                    <input asp-for="PrecioVenta" type="number" step="0.01" class="form-control" placeholder="0.00" />
                    <span asp-validation-for="PrecioVenta" class="validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="CodigoCabys">CABYS</label>
                    <input asp-for="CodigoCabys" class="form-control" placeholder="000000" />
                    <span asp-validation-for="CodigoCabys" class="validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Empresa">Empresa</label>
                    <input asp-for="Empresa" class="form-control" placeholder="Empresa" />
                    <span asp-validation-for="Empresa" class="validation-error"></span>
                </div>
            </div>

            <!-- Detalle -->
            <div class="form-group">
                <label asp-for="Detalle">Detalle</label>
                <textarea asp-for="Detalle" class="form-control" placeholder="Descripción..." rows="2"></textarea>
                <span asp-validation-for="Detalle" class="validation-error"></span>
            </div>

            <!-- TALLAS -->
            <div class="section-title">📏 Tallas</div>

            <table class="tallas-table" id="tablaTallas">
                <thead><tr><th>Talla</th><th>Cant</th><th></th></tr></thead>
                <tbody>
                    <tr>
                        <td><input type="text" name="Tallas[0].Numero" placeholder="38" required /></td>
                        <td><input type="number" name="Tallas[0].Cantidad" placeholder="0" required /></td>
                        <td></td>
                    </tr>
                </tbody>
            </table>

            <button type="button" class="btn-add" onclick="agregarTalla()">➕ Agregar</button>

            <!-- FOTOS -->
            <div class="section-title">📸 Fotos</div>
            <input type="file" name="imagenes" multiple class="file-input" />

            <!-- BOTONES -->
            <div class="action-buttons">
                <a asp-action="Index" class="btn-secondary">Cancelar</a>
                <button type="submit" class="btn-primary">💾 Guardar</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        let idx = 1;
        function agregarTalla() {
            const tabla = document.querySelector("#tablaTallas tbody");
            tabla.insertAdjacentHTML("beforeend", `
                <tr>
                    <td><input type="text" name="Tallas[${idx}].Numero" placeholder="38" required /></td>
                    <td><input type="number" name="Tallas[${idx}].Cantidad" placeholder="0" required /></td>
                    <td><button type="button" class="btn-remove" onclick="eliminarFila(this)">✕</button></td>
                </tr>
            `);
            idx++;
        }
        function eliminarFila(b) { b.closest("tr").remove(); reindexar(); }
        function reindexar() {
            const filas = document.querySelectorAll("#tablaTallas tbody tr");
            filas.forEach((f, i) => {
                f.querySelectorAll("input")[0].setAttribute("name", `Tallas[${i}].Numero`);
                f.querySelectorAll("input")[1].setAttribute("name", `Tallas[${i}].Cantidad`);
            });
            idx = filas.length;
        }
    </script>
}